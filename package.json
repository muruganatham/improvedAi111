{
  "name": "data-analytics-platform",
  "version": "1.0.0",
  "description": "Analytics platform syncing data from multiple sources like Close.com, Stripe, and databases",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"pnpm --filter api run dev\" \"pnpm dlx inngest-cli@latest dev\"",
    "build": "pnpm run lint:fix:all && pnpm run api:build && node scripts/check-connector-agnosticism.js",
    "start": "node dist/index.js",
    "test": "jest",
    "format": "prettier --write \"api/**/*.ts\"",
    "sync": "ts-node api/src/sync/cli.ts",
    "sync:help": "ts-node api/src/sync/cli.ts --help",
    "migrate": "ts-node -r dotenv/config api/src/migrations/cli.ts",
    "query": "tsx api/src/sync/query-runner.ts",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:rebuild": "docker compose down && docker compose build && docker compose up -d",
    "docker:clean": "docker compose down -v",
    "api:dev": "pnpm --filter api run dev",
    "api:build": "pnpm --filter api run build",
    "api:start": "pnpm --filter api run start",
    "api:lint": "pnpm --filter api run lint",
    "api:lint:fix": "pnpm --filter api run lint:fix",
    "lint:all": "pnpm run api:lint && node scripts/check-connector-agnosticism.js",
    "lint:fix:all": "pnpm run api:lint:fix && node scripts/check-connector-agnosticism.js",
    "install:all": "pnpm install -r",
    "cf:login": "wrangler login",
    "cf:deploy": "wrangler deploy --config cloudflare/wrangler.toml",
    "cf:tail": "wrangler tail --config cloudflare/wrangler.toml",
    "cf:kv:create": "wrangler kv:namespace create MAKO_PR_DEPLOYMENTS",
    "cf:kv:list": "wrangler kv:key list --namespace-id=$CLOUDFLARE_KV_NAMESPACE_ID",
    "preview-db:list": "./scripts/manage-preview-db.sh list",
    "preview-db:create": "./scripts/manage-preview-db.sh create",
    "preview-db:delete": "./scripts/manage-preview-db.sh delete",
    "prepare": "husky"
  },
  "keywords": [
    "analytics",
    "data-sync",
    "close-crm",
    "stripe",
    "mongodb",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@types/inquirer": "^8.2.11",
    "@types/node-cron": "^3.0.11",
    "api": "^6.1.3",
    "axios": "^1.6.2",
    "bson": "^6.2.0",
    "commander": "^14.0.0",
    "cron-parser": "^5.3.0",
    "dotenv": "^16.3.1",
    "eslint-plugin-prettier": "^5.4.1",
    "inngest": "^3.39.2",
    "inquirer": "^8.2.6",
    "js-yaml": "^4.1.0",
    "mongodb": "^6.3.0",
    "node-cron": "^4.1.1",
    "stripe": "^14.25.0",
    "zod": "^3.25.67"
  },
  "lint-staged": {
    "api/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.10.4",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "concurrently": "^8.2.2",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^10.1.5",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.2.7",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.3",
    "wrangler": "^3.99.0",
    "yaml": "^2.8.0"
  }
}
